# API Keys
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Database Configuration
# For local development with SQLite:
# DATABASE_URL=sqlite:///./orchestrix.db

# For Supabase PostgreSQL (Production):
# Get these from your Supabase project dashboard > Settings > Database
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Alternative direct PostgreSQL URL format:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/[DBNAME]

# Set to "true" to enable async PostgreSQL (requires asyncpg)
# Default: "false" (uses synchronous psycopg2 for simpler migration)
USE_ASYNC=false

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
